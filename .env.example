# ── stdio (headless) mode ────────────────────────────────────────────────────
# The MCP authenticates as a Didit USER via a Bearer access token — there is no
# API-key mode. For headless stdio, supply a user access token (optionally with a
# default org/app below). In hosted mode this comes from the OAuth flow instead.
DIDIT_ACCESS_TOKEN=

# ── Shared base URLs (override only for a private/self-hosted Didit) ──────────
DIDIT_API_BASE_URL=https://verification.didit.me/v3
DIDIT_AUTH_BASE_URL=https://apx.didit.me/auth/v2

# ── Hosted (HTTP/OAuth) mode ─────────────────────────────────────────────────
MCP_PORT=3000
MCP_RESOURCE_URI=https://mcp.didit.me
MCP_AUTHORIZATION_SERVER_ORIGIN=https://business.didit.me
MCP_TOKEN_VERIFY_MODE=introspection
MCP_OAUTH_INTROSPECT_URL=https://apx.didit.me/auth/v2/introspect/
# Basic-auth credentials the resource server uses to call introspection.
# Provide these via your secret manager in production — never commit real values.
MCP_OAUTH_CLIENT_ID=
MCP_OAUTH_CLIENT_SECRET=
MCP_SCOPES_SUPPORTED=didit:management didit:verification

# Optional: auto-fill scope for single-org/app deployments
MCP_DEFAULT_ORG=
MCP_DEFAULT_APP=
